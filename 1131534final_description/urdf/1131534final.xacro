<joint name="Revolute_lf_wheel" type="continuous">
  <origin xyz="0.25 0.25 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lf_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="Revolute_lb_wheel" type="continuous">
  <origin xyz="-0.25 0.25 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lb_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="Revolute_rb_wheel" type="continuous">
  <origin xyz="-0.25 -0.25 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="rb_wheel_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
</joint>

<joint name="Revolute_rf_wheel" type="continuous">
  <origin xyz="0.25 -0.25 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="rf_wheel_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
</joint>

<joint name="body_arm" type="continuous">
  <origin xyz="0.225 -0.016592 0.225" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="down_arm_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <!-- 必須確保有這一行，Gazebo 的馬達才有力氣！ -->
  <limit effort="1000.0" velocity="2.0"/>
</joint>

<joint name="arms" type="continuous">
  <origin xyz="-0.45 0.04 0.0" rpy="0 0 0"/>
  <parent link="down_arm_1"/>
  <child link="up_arm_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <!-- 必須確保有這一行，Gazebo 的馬達才有力氣！ -->
  <limit effort="1000.0" velocity="2.0"/>
</joint>

<joint name="backet_arm" type="continuous">
  <origin xyz="0.0 0.0 0.45" rpy="0 0 0"/>
  <parent link="up_arm_1"/>
  <child link="basket_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <!-- 必須確保有這一行，Gazebo 的馬達才有力氣！ -->
  <limit effort="1000.0" velocity="2.0"/>
</joint>

</robot>
